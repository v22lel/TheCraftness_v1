/execute if score #dir_sign escapemap_castle_elevator matches -1 as @e[type=minecraft:shulker,tag=escapemap_castle_elevator] at @s run tp @s ~ ~-1.0 ~
/execute if score #dir_sign escapemap_castle_elevator matches -1 run data merge entity @e[type=minecraft:shulker,tag=escapemap_castle_elevator,limit=1] {Peek:100b}
/execute if score #dir_sign escapemap_castle_elevator matches -1 as @e[type=minecraft:shulker,tag=escapemap_castle_elevator] run data merge entity @s {Peek:100b}

/function escapemap:puzzles/castle/layer2/elevators/elevator/calculate_distance
/scoreboard players set #a escapemap_castle_elevator 0
/scoreboard players set #b escapemap_castle_elevator 0
/scoreboard players set #active escapemap_castle_elevator 0
/scoreboard players set #cycle escapemap_castle_elevator 0
/scoreboard players set #tick escapemap_castle_elevator 0

#file: ./elevator/tick
/execute if score #running escapemap_castle_elevator matches 1 run function escapemap:puzzles/castle/layer2/elevators/elevator/force_attach_face
/scoreboard players set #do_step escapemap_castle_elevator 0
/execute if score #running escapemap_castle_elevator matches 1 run scoreboard players add #tick escapemap_castle_elevator 1
/execute if score #running escapemap_castle_elevator matches 1 if score #tick escapemap_castle_elevator >= #tick_divisor escapemap_castle_elevator run scoreboard players set #do_step escapemap_castle_elevator 1
/execute if score #do_step escapemap_castle_elevator matches 1 run scoreboard players set #tick escapemap_castle_elevator 0
/execute if score #do_step escapemap_castle_elevator matches 1 if score #active escapemap_castle_elevator matches 0 run function escapemap:puzzles/castle/layer2/elevators/elevator/step_a
/execute if score #do_step escapemap_castle_elevator matches 1 if score #active escapemap_castle_elevator matches 1 run function escapemap:puzzles/castle/layer2/elevators/elevator/step_b

#file: ./elevator/force_attach_face
/execute as @e[type=minecraft:shulker,tag=escapemap_castle_elevator] run data merge entity @s {AttachFace:0b}

#file: ./elevator/step_a
/scoreboard players add #a escapemap_castle_elevator 1
/execute if score #dir_sign escapemap_castle_elevator matches 1 as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_a] store result entity @s Peek byte 1 run scoreboard players get #a escapemap_castle_elevator
/scoreboard players set #peek_tmp escapemap_castle_elevator 100
/execute if score #dir_sign escapemap_castle_elevator matches -1 run scoreboard players operation #peek_tmp escapemap_castle_elevator -= #a escapemap_castle_elevator
/execute if score #dir_sign escapemap_castle_elevator matches -1 as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_a] store result entity @s Peek byte 1 run scoreboard players get #peek_tmp escapemap_castle_elevator
/execute if score #dir_sign escapemap_castle_elevator matches 1 run execute as @e[type=minecraft:block_display,tag=escapemap_castle_elevator_display] at @s run tp @s ~ ~0.01 ~
/execute if score #dir_sign escapemap_castle_elevator matches -1 run execute as @e[type=minecraft:block_display,tag=escapemap_castle_elevator_display] at @s run tp @s ~ ~-0.01 ~
/execute if score #a escapemap_castle_elevator matches 100.. run function escapemap:puzzles/castle/layer2/elevators/elevator/finish_a

#file: ./elevator/step_b
/scoreboard players add #b escapemap_castle_elevator 1
/execute if score #dir_sign escapemap_castle_elevator matches 1 as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_b] store result entity @s Peek byte 1 run scoreboard players get #b escapemap_castle_elevator
/scoreboard players set #peek_tmp escapemap_castle_elevator 100
/execute if score #dir_sign escapemap_castle_elevator matches -1 run scoreboard players operation #peek_tmp escapemap_castle_elevator -= #b escapemap_castle_elevator
/execute if score #dir_sign escapemap_castle_elevator matches -1 as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_b] store result entity @s Peek byte 1 run scoreboard players get #peek_tmp escapemap_castle_elevator
/execute if score #dir_sign escapemap_castle_elevator matches 1 run execute as @e[type=minecraft:block_display,tag=escapemap_castle_elevator_display] at @s run tp @s ~ ~0.01 ~
/execute if score #dir_sign escapemap_castle_elevator matches -1 run execute as @e[type=minecraft:block_display,tag=escapemap_castle_elevator_display] at @s run tp @s ~ ~-0.01 ~
/execute if score #b escapemap_castle_elevator matches 100.. run function escapemap:puzzles/castle/layer2/elevators/elevator/finish_b

#file: ./elevator/finish_a
/execute if score #dir_sign escapemap_castle_elevator matches 1 run execute as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_b] at @s run tp @s ~ ~2 ~
/execute if score #dir_sign escapemap_castle_elevator matches -1 run execute as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_a] at @s run tp @s ~ ~-2 ~
/execute as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_a,limit=1] at @s run function escapemap:puzzles/castle/layer2/elevators/elevator/nudge_players
/execute if score #dir_sign escapemap_castle_elevator matches 1 as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_a] run data merge entity @s {Peek:0b,AttachFace:0b}
/execute if score #dir_sign escapemap_castle_elevator matches -1 as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_a] run data merge entity @s {Peek:100b,AttachFace:0b}
/scoreboard players set #a escapemap_castle_elevator 0
/scoreboard players set #active escapemap_castle_elevator 1
/scoreboard players add #cycle escapemap_castle_elevator 1
/execute if score #cycle escapemap_castle_elevator >= #max_cycles escapemap_castle_elevator run function escapemap:puzzles/castle/layer2/elevators/elevator/arrive

#file: ./elevator/finish_b
/execute if score #dir_sign escapemap_castle_elevator matches 1 run execute as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_a] at @s run tp @s ~ ~2 ~
/execute if score #dir_sign escapemap_castle_elevator matches -1 run execute as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_b] at @s run tp @s ~ ~-2 ~
/execute as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_b,limit=1] at @s run function escapemap:puzzles/castle/layer2/elevators/elevator/nudge_players
/execute if score #dir_sign escapemap_castle_elevator matches 1 as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_b] run data merge entity @s {Peek:0b,AttachFace:0b}
/execute if score #dir_sign escapemap_castle_elevator matches -1 as @e[type=minecraft:shulker,tag=escapemap_castle_elevator_b] run data merge entity @s {Peek:100b,AttachFace:0b}
/scoreboard players set #b escapemap_castle_elevator 0
/scoreboard players set #active escapemap_castle_elevator 0
/scoreboard players add #cycle escapemap_castle_elevator 1
/execute if score #cycle escapemap_castle_elevator >= #max_cycles escapemap_castle_elevator run function escapemap:puzzles/castle/layer2/elevators/elevator/arrive

#file: ./elevator/nudge_players
/execute as @a[x=-167.5,y=-59,z=-47.5,dx=10,dy=18,dz=10] at @s run tp @s ~ ~0.1 ~

#file: ./elevator/arrive
/scoreboard players set #running escapemap_castle_elevator 0
/scoreboard players operation #current_station escapemap_castle_elevator = #target_station escapemap_castle_elevator
/execute if score #current_station escapemap_castle_elevator matches 0 run function escapemap:puzzles/castle/layer2/elevators/elevator/place_station_0_blocks
/execute if score #current_station escapemap_castle_elevator matches 1 run function escapemap:puzzles/castle/layer2/elevators/elevator/place_station_1_blocks
/execute if score #current_station escapemap_castle_elevator matches 2 run function escapemap:puzzles/castle/layer2/elevators/elevator/place_station_2_blocks
/execute if score #current_station escapemap_castle_elevator matches 3 run function escapemap:puzzles/castle/layer2/elevators/elevator/place_station_3_blocks
/execute as @a[x=-167.5,y=-59,z=-47.5,dx=10,dy=18,dz=10] at @s run tp @s ~ ~0.1 ~
/function escapemap:puzzles/castle/layer2/elevators/elevator_listener/end
/execute as @e[type=minecraft:shulker,tag=escapemap_castle_elevator] run data merge entity @s {Peek:0b,AttachFace:0b}
/function escapemap:puzzles/castle/layer2/elevators/elevator/despawn_entities

#file: ./elevator/despawn_entities
/execute as @e[tag=escapemap_castle_elevator] at @s run tp @s 0 -64 0
/kill @e[type=minecraft:shulker,tag=escapemap_castle_elevator]
/kill @e[type=minecraft:block_display,tag=escapemap_castle_elevator_display]

#file: ./elevator/stop
/scoreboard players set #running escapemap_castle_elevator 0
/execute as @e[type=minecraft:shulker,tag=escapemap_castle_elevator] run data merge entity @s {Peek:0b,AttachFace:0b}
/kill @e[type=minecraft:shulker,tag=escapemap_castle_elevator]
/kill @e[type=minecraft:block_display,tag=escapemap_castle_elevator_display]

#file: ./elevator/cleanup
/scoreboard players set #running escapemap_castle_elevator 0
/function escapemap:puzzles/castle/layer2/elevators/elevator/despawn_entities
