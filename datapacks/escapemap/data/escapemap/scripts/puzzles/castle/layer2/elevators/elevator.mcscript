#file: ./elevator/load
/scoreboard objectives add escapemap_castle_elevator dummy
/scoreboard players set #running escapemap_castle_elevator 0
/scoreboard players set #tick_divisor escapemap_castle_elevator 2
/scoreboard players set #current_station escapemap_castle_elevator 0

#file: ./elevator/reset
/scoreboard players set #running escapemap_castle_elevator 0
/function escapemap:puzzles/castle/layer2/elevators/elevator/despawn_entities
/scoreboard players set #current_station escapemap_castle_elevator 0
/function escapemap:puzzles/castle/layer2/elevators/elevator/place_station_0_blocks
/function escapemap:puzzles/castle/layer2/elevators/elevator/clear_station_1_blocks
/function escapemap:puzzles/castle/layer2/elevators/elevator/clear_station_2_blocks
